# Server Configurations
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database Connection
MONGO_URI=mongodb://127.0.0.1:27017/anek

# JWT Secret Keys
JWT_ACCESS_SECRET=your_super_secret_access_token_key_123!
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_456!
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Cloudinary Setup (for Media Uploads)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Rate Limit Config
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes in ms
RATE_LIMIT_MAX_REQ=100      # max requests per window
